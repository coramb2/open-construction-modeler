# Get these from your Supabase project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only — used for admin operations (e.g. server-side storage cleanup).
# NEVER prefix this with NEXT_PUBLIC_ or it will be exposed to the browser.
# https://app.supabase.com/project/_/settings/api (service_role key)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
